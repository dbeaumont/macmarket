        "http://localhost:3001/*"
      ],
      "webOrigins": [
        "http://localhost:5174",
        "http://localhost:3001"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:5174/*##http://localhost:3001/*"
      }
    }
  ],
