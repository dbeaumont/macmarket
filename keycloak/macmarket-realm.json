{
  "realm": "macmarket",
  "enabled": true,
  "registrationAllowed": true,
  "registrationEmailAsUsername": true,
  "rememberMe": true,
  "loginWithEmailAllowed": true,
  "defaultRoles": ["CUSTOMER"],
  "roles": {
    "realm": [
      {
        "name": "CUSTOMER",
        "description": "Client de la boutique"
      },
      {
        "name": "MANAGER",
        "description": "Gestionnaire backoffice"
      },
      {
        "name": "ADMIN",
        "description": "Administrateur",
        "composite": true,
        "composites": {
          "realm": ["MANAGER"]
        }
      }
    ]
  },
  "defaultDefaultClientScopes": ["web-origins", "acr", "profile", "roles", "email"],
  "clients": [
    {
      "clientId": "macmarket-shop",
      "name": "MacMarket Boutique",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "redirectUris": [
        "http://localhost:5173/*",
        "http://localhost:3000/*"
      ],
      "webOrigins": [
        "http://localhost:5173",
        "http://localhost:3000"
      ],
      "attributes": {
        "pkce.code.challenge.method": "S256",
        "post.logout.redirect.uris": "http://localhost:5173/*##http://localhost:3000/*"
      }
    },
    {
      "clientId": "macmarket-admin",
      "name": "MacMarket Backoffice",
      "enabled": true,
